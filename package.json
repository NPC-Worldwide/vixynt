{
  "name": "vixynt",
  "version": "0.1.0",
  "description": "Vixynt - A standalone image and diffusion studio",
  "author": "Chris Agostino <info@npcworldwi.de>",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && npm run build:preload && concurrently \"vite\" \"electron . --dev\"",
    "build": "npm run build:renderer && npm run build:electron && npm run build:preload && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"require('fs').renameSync('dist-electron/preload.js', 'dist-electron/preload.cjs')\"",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.471.1",
    "npcts": "^0.1.18",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "com.npcworldwide.vixynt",
    "productName": "Vixynt",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "vixynt.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "vixynt.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "vixynt.png",
      "target": [
        "deb",
        "AppImage"
      ]
    }
  }
}
